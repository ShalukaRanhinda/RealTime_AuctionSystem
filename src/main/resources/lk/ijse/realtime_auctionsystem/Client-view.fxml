<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.realtime_auctionsystem.Client.ClientController">
    <children>
        <Label layoutX="14.0" layoutY="14.0" text="Auction Participant" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <Label fx:id="lblStatus" layoutX="300.0" layoutY="20.0" text="Not Connected" textFill="#7f8c8d">
            <font>
                <Font name="System Italic" size="16.0" />
            </font>
        </Label>
        
        <Label fx:id="lblItemName" layoutX="14.0" layoutY="50.0" textFill="#8e44ad">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>
        
        <Label fx:id="lblHighestBid" layoutX="14.0" layoutY="75.0" text="Current Highest Bid: LKR 0.0" textFill="#232b26">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        
        <TextField fx:id="txtBidAmount" layoutX="14.0" layoutY="115.0" prefHeight="35.0" prefWidth="200.0" promptText="Enter bid amount (LKR)" />
        <Button fx:id="btnPlaceBid" layoutX="230.0" layoutY="115.0" mnemonicParsing="false" onAction="#handlePlaceBid" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="Place Bid" />
        
        <TextArea fx:id="txtArea" editable="false" layoutX="14.0" layoutY="160.0" prefHeight="226.0" prefWidth="572.0" style="-fx-font-family: 'Consolas'; -fx-font-size: 14px;" />
    </children>
</AnchorPane>
